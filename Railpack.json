{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11",
    "node": "20"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install -r backend/requirements.txt",
        "cd frontend && npm install"
      ]
    },
    "build": {
      "commands": [
        "cd frontend && npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn main:app --host 0.0.0.0 --port $PORT"
  }
}
